[project]
name = "{{ mcp_server_slug }}-mcp"
version = "0.1.0"
description = "MCP server for {{ project_name }}"
requires-python = ">=3.12"
dependencies = [
    "fastmcp>=2.0.0",
    "httpx>=0.27.0",
    "python-dotenv>=1.0.0",
]

[project.scripts]
{{ mcp_server_slug }} = "src.server:main"

[tool.hatch.build.targets.wheel]
packages = ["src"]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"
