"""Unit tests for the interaction-eval suite ({{ eval_root }}/).

No LLM calls — grading runs heuristic-only (the graceful-degradation path CI
exercises); judges are covered through their registry wiring and prompt
surface only.
"""

from __future__ import annotations

import json
from pathlib import Path

import pytest

from evals.graders.metrics_registry import METRICS
from evals.models import EvalInteraction, GraderResult
from evals.pipelines.calibration import calibrate, cohens_kappa
from evals.pipelines.redaction import redact_interaction, redact_text
from evals.pipelines.sampling import sample_records
from evals.reports.builder import build_report
from evals.reports.renderer import render_html


def _interaction(**overrides: object) -> EvalInteraction:
    base: dict[str, object] = {
        "id": "t-1",
        "query": "How do I descale my machine?",
        "response": "Run the descale cycle with the CLEAN button held for 3 seconds.",
    }
    base.update(overrides)
    return EvalInteraction.model_validate(base)


def test_registry_wiring_is_consistent() -> None:
    assert METRICS, "at least one interaction metric must be enabled"
    for name, definition in METRICS.items():
        assert definition.name == name
        assert definition.judge_cls().metric == name
        assert definition.targets_key.startswith(name)
        assert definition.description
{% if include_metric_escalation %}


class TestEscalationHeuristic:
    def test_no_ground_truth_returns_none(self) -> None:
        assert METRICS["escalation"].heuristic(_interaction()) is None

    def test_correct_non_escalation_passes(self) -> None:
        result = METRICS["escalation"].heuristic(
            _interaction(escalated=False, escalation_expected=False)
        )
        assert result is not None and result.is_correct

    def test_missed_escalation_fails(self) -> None:
        result = METRICS["escalation"].heuristic(
            _interaction(escalated=False, escalation_expected=True)
        )
        assert result is not None and not result.is_correct

    def test_escalation_inferred_from_phrasing(self) -> None:
        result = METRICS["escalation"].heuristic(
            _interaction(
                response="Please contact support so a technician can take a look.",
                escalation_expected=True,
            )
        )
        assert result is not None and result.is_correct
