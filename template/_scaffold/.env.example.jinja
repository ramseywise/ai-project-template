# Copied to .env by project_init.sh — fill in real values, never commit .env itself.

# --- LLM provider ---
ANTHROPIC_API_KEY=
{%- if primary_chat_agent in ['lg_agent', 'both'] %}
LG_MODEL=claude-haiku-4-5-20251001

# --- Example agent ({{ source_root }}/agents/{{ lg_agent_dir }}) ---
LG_PORT=8010
VECTORDB_PATH=data/stores/vectordb.duckdb
LG_CHECKPOINTER=memory   # memory | sqlite

# --- MCP client ({{ source_root }}/agents/{{ lg_agent_dir }}/clients/mcp.py) ---
MCP_ENABLED={{ 'true' if include_mcp_server else 'false' }}
MCP_SERVER_DIR=mcp_servers/{{ mcp_server_slug | default(project_slug) }}
{%- endif %}
{%- if include_rag_agent %}

# --- Example agent ({{ source_root }}/agents/rag_agent) — same corpus, embedding-based retrieval ---
RAG_MODEL=claude-haiku-4-5-20251001
RAG_PORT=8011
RAG_VECTORDB_PATH=data/stores/rag_vectordb.duckdb
RAG_CHECKPOINTER=memory
EMBEDDING_MODEL=all-MiniLM-L6-v2
CONFIDENCE_THRESHOLD=0.25
{%- endif %}
{%- if primary_chat_agent in ['adk_agent', 'both'] %}

# --- Example agent ({{ source_root }}/agents/{{ adk_agent_dir }}) — Google ADK, MCP via native McpToolset ---
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_API_KEY=
ADK_PORT=8000
GATEWAY_API_KEY=
{%- endif %}

# --- Observability (optional — leave blank to disable) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT={{ project_slug }}
