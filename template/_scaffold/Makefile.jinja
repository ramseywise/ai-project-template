{% set lg = lg_agent_dir | replace("_", "-") -%}
{% set adk = adk_agent_dir | replace("_", "-") -%}
.PHONY: setup corpus-preprocess \
{%- if primary_chat_agent in ["lg_agent", "both"] %}
        corpus-ingest {{ lg }}-up {{ lg }}-down {{ lg }}-wait {{ lg }}-chat \
{%- endif %}
{%- if include_rag_agent %}
        rag-corpus-ingest rag-up rag-down rag-wait rag-chat \
{%- endif %}
{%- if primary_chat_agent in ["adk_agent", "both"] %}
        {{ adk }}-up {{ adk }}-down {{ adk }}-wait {{ adk }}-chat \
{%- endif %}
        eval-heuristic eval-gate eval-render \
{%- if include_interaction_evals %}
        eval-grade eval-grade-gate eval-interactions-report eval-calibrate \
{%- endif %}
{%- if include_promptfoo %}
        promptfoo-eval \
{%- endif %}
        nbks-corpus test test-smoke test-integration \
        lint lint-check typecheck \
{%- if primary_backend_language in ["typescript", "both"] %}
        ts-install ts-lint ts-typecheck ts-test ts-build ts-dev \
{%- endif %}
{%- if has_typescript and ts_agent_framework == "vercel_ai_sdk" %}
        ts-agent-eval \
{%- endif %}
        docker-up docker-down

# {{ py_project_root }}/{{ ai_source_root }}/ holds "agents" (imported bare, e.g. `agents.{{ lg_agent_dir }}`); "core"
# and "{{ eval_root }}" live at the project root — both need to be on PYTHONPATH
# for anything invoked outside of pytest (which reads pythonpath from pyproject.toml).
PY := PYTHONPATH={{ py_project_root }}/{{ ai_source_root }}:{% if include_ml %}{{ py_project_root }}:{% endif %}. uv run python
UVICORN := PYTHONPATH={{ py_project_root }}/{{ ai_source_root }}:. uv run uvicorn

setup:
	./project_init.sh

{% if has_corpus_pipeline -%}
# --- Corpus data pipeline (core/pipelines/corpus/) ---
corpus-preprocess:
	$(PY) -m core.pipelines.corpus preprocess

{% endif -%}
{% if primary_chat_agent in ["lg_agent", "both"] -%}
corpus-ingest: corpus-preprocess
	$(PY) -m core.pipelines.corpus ingest

# --- Chat agent ({{ py_project_root }}/{{ ai_source_root }}/agents/{{ lg_agent_dir }}, LangGraph) ---
{{ lg }}-up:
	$(UVICORN) agents.{{ lg_agent_dir }}.main:app --port $${LG_PORT:-8010} --reload &

{{ lg }}-down:
	pkill -f "uvicorn agents.{{ lg_agent_dir }}.main:app" 2>/dev/null || true

{{ lg }}-wait:
	@for i in $$(seq 1 30); do \
		curl -sf http://localhost:$${LG_PORT:-8010}/health >/dev/null && echo "{{ lg_agent_dir }} is up" && exit 0; \
		sleep 1; \
	done; \
	echo "{{ lg_agent_dir }} did not become healthy in time" >&2; exit 1

{{ lg }}-chat:
	curl -s -X POST http://localhost:$${LG_PORT:-8010}/chat \
		-H "Content-Type: application/json" \
		-d '{"message": "How do I descale the machine?", "thread_id": "smoke-test"}' | uv run python -m json.tool

{% endif -%}
{% if include_rag_agent -%}
# --- Example agent ({{ py_project_root }}/{{ ai_source_root }}/agents/rag_agent) — same corpus, embedding-based retrieval ---
rag-corpus-ingest: corpus-preprocess
	$(PY) -m core.pipelines.corpus rag-ingest

rag-up:
	$(UVICORN) agents.rag_agent.main:app --port $${RAG_PORT:-8011} --reload &

rag-down:
	pkill -f "uvicorn agents.rag_agent.main:app" 2>/dev/null || true

rag-wait:
	@for i in $$(seq 1 30); do \
		curl -sf http://localhost:$${RAG_PORT:-8011}/health >/dev/null && echo "rag_agent is up" && exit 0; \
		sleep 1; \
	done; \
	echo "rag_agent did not become healthy in time" >&2; exit 1

rag-chat:
	curl -s -X POST http://localhost:$${RAG_PORT:-8011}/chat \
		-H "Content-Type: application/json" \
		-d '{"message": "How do I descale the machine?", "thread_id": "smoke-test"}' | uv run python -m json.tool

{% endif -%}
{% if primary_chat_agent in ["adk_agent", "both"] -%}
# --- Chat agent ({{ py_project_root }}/{{ ai_source_root }}/agents/{{ adk_agent_dir }}, Google ADK) — MCP via McpToolset ---
{{ adk }}-up:
	$(UVICORN) agents.{{ adk_agent_dir }}.gateway.main:app --port $${ADK_PORT:-8000} --reload &

{{ adk }}-down:
	pkill -f "uvicorn agents.{{ adk_agent_dir }}.gateway.main:app" 2>/dev/null || true

{{ adk }}-wait:
	@for i in $$(seq 1 30); do \
		curl -sf http://localhost:$${ADK_PORT:-8000}/health >/dev/null && echo "{{ adk_agent_dir }} is up" && exit 0; \
		sleep 1; \
	done; \
	echo "{{ adk_agent_dir }} did not become healthy in time" >&2; exit 1

# SSE requires the stream open before POSTing — background curl on the stream,
# give it a moment to connect, then trigger the turn.
{{ adk }}-chat:
	curl -sN "http://localhost:$${ADK_PORT:-8000}/chat/stream?session_id=smoke-test" & \
	STREAM_PID=$$!; \
	sleep 1; \
	curl -s -X POST http://localhost:$${ADK_PORT:-8000}/chat \
		-H "Content-Type: application/json" \
		-d '{"session_id": "smoke-test", "request_id": "smoke-1", "message": "How do I descale the machine?"}'; \
	sleep 5; kill $$STREAM_PID 2>/dev/null || true

{% endif -%}
# --- Evals ({{ eval_root }}/) ---
{% if has_corpus_pipeline -%}
# Retrieval golden-QA gate — grades the corpus retrieval backend(s) present.
eval-heuristic:
	$(PY) -m {{ eval_root }}.pipelines.run heuristic

# Same run, but exits non-zero when any {{ eval_root }}/targets.yaml metric is
# below target — the CI-able form of DESIGN.md's Evaluation table.
eval-gate:
	$(PY) -m {{ eval_root }}.pipelines.run heuristic --gate

eval-render:
	$(PY) -m {{ eval_root }}.pipelines.run render

{% endif -%}
{% if include_interaction_evals -%}
# Interaction evals ({{ eval_root }}/graders/{heuristic,judges}) — heuristics
# always run; LLM judges join when ANTHROPIC_API_KEY is set.
eval-grade:
	$(PY) -m {{ eval_root }}.pipelines.grade run

eval-grade-gate:
	$(PY) -m {{ eval_root }}.pipelines.grade run --gate

eval-interactions-report:
	$(PY) -m {{ eval_root }}.pipelines.grade report

# Heuristic-vs-judge agreement (needs a graded run that included judges).
eval-calibrate:
	$(PY) -m {{ eval_root }}.pipelines.calibration

{% endif -%}
{% if include_promptfoo -%}
promptfoo-eval:
	npx promptfoo eval -c promptfoo.config.yaml

{% endif -%}
{% if has_corpus_pipeline -%}
# --- Notebooks (nbks/, Marimo) ---
nbks-corpus:
	PYTHONPATH={{ py_project_root }}/{{ ai_source_root }}:. uv run marimo run nbks/corpus_analysis.py

{% endif -%}
# --- Tests ---
test:
	uv run pytest tests/unit -q

test-smoke:
	uv run pytest tests/smoke -q

test-integration:
	uv run pytest tests/integration -q -m integration

# --- Lint / typecheck ---
# Scoped to this project's own source, not the whole repo root — .claude/.agents/
# ship vendored reference material (e.g. mcp-builder's example scripts) that
# isn't held to this project's lint config and was never meant to be.
{% if primary_backend_language in ["python", "both"] -%}
LINT_PATHS := {{ py_project_root }}/{{ ai_source_root }} core {{ eval_root }} tests{% if include_ml %} {{ py_project_root }}/{{ ml_source_root }}{% endif %}

lint:
	uv run ruff check $(LINT_PATHS) --fix
	uv run ruff format $(LINT_PATHS)

lint-check:
	uv run ruff check $(LINT_PATHS)
	uv run ruff format --check $(LINT_PATHS)

typecheck:
	uv run pyright
{% else -%}
lint:
	@echo "Python lint skipped (primary_backend_language={{ primary_backend_language }})"

lint-check:
	@echo "Python lint-check skipped (primary_backend_language={{ primary_backend_language }})"

typecheck:
	@echo "Python typecheck skipped (primary_backend_language={{ primary_backend_language }})"
{% endif -%}

{% if primary_backend_language in ["typescript", "both"] -%}
# --- TS backend service ({{ ts_project_root }}/) ---
ts-install:
	cd {{ ts_project_root }} && npm install

ts-lint:
	cd {{ ts_project_root }} && npm run lint

ts-typecheck:
	cd {{ ts_project_root }} && npm run typecheck

ts-test:
	cd {{ ts_project_root }} && npm test

ts-build:
	cd {{ ts_project_root }} && npm run build

ts-dev:
	cd {{ ts_project_root }} && npm run dev

{% if ts_agent_framework == "vercel_ai_sdk" -%}
# Answer-only smoke eval, NOT retrieval grading (the TS agent has no search
# step) — see agent/eval/run.ts's docstring. Requires the server already
# running (`make ts-dev` in another terminal) and ANTHROPIC_API_KEY set.
ts-agent-eval:
	cd {{ ts_project_root }} && GOLDEN_QA_PATH=$(CURDIR)/data/raw_corpus/golden_qa.jsonl npm run eval

{% endif -%}
{% endif -%}
# --- Docker (infrastructure/containers) ---
docker-up:
	docker compose -f infrastructure/containers/docker-compose.yml up --build

docker-down:
	docker compose -f infrastructure/containers/docker-compose.yml down
