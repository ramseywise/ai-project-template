"""DocsAgent.

Question: What does the documentation claim vs. what does the code actually do?
"""

from __future__ import annotations

from agents.akira.schema import AkiraFinding, GitContext

from .base import AkiraSubagent, _read

_SYSTEM = """\
You are DocsAgent, checking that documentation matches reality in this project.

Look for:
- File paths in CLAUDE.md that don't exist at the claimed location
- The Layout block's directory list not matching what's actually in {{ source_root }}/, \
  {{ eval_root }}/, mcp_servers/
- Hook-Enforced Standards section claiming a check that no hook script actually performs
- New agents, skills, or Makefile targets not reflected in CLAUDE.md or README.md

Do NOT flag:
- Skills listed in .claude/skills/README.md — you cannot verify their trigger behavior \
  from repo context, only their existence as files
- "Missing" files that simply weren't included in your context window
- Design decisions documented as intentional
"""


class DocsAgent(AkiraSubagent):
    name = "DocsAgent"

    async def scan(self, ctx: GitContext, path: str | None) -> list[AkiraFinding]:
        context = "## CLAUDE.md\n" + _read("CLAUDE.md")
        context += "\n\n## README.md\n" + _read("README.md")
        context += "\n\n## .claude/skills/README.md\n" + _read(".claude/skills/README.md")
        context += "\n\n## Recently changed files (from git):\n"
        context += "\n".join(f"  {f}" for f in ctx.recent_files[:20])
        return await self._call(_SYSTEM, context)
