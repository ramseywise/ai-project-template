"""SafeguardAgent.

Question: Does each example agent have a real guardrail against prompt-injection
or off-topic input, and is the mechanism documented accurately?
"""

from __future__ import annotations

from agents.akira.schema import AkiraFinding, GitContext

from .base import AkiraSubagent, _read

_SYSTEM = """\
You are SafeguardAgent, reviewing this project's example agents for guardrail gaps.

This project has these example agents:
{%- if primary_chat_agent in ["lg_agent", "both"] %}
  {{ source_root }}/agents/lg_agent  — has guardrail_node (nodes/guardrail.py), a \
    keyword-pattern check before retrieval
{%- endif %}
  {{ source_root }}/agents/rag_agent — retrieval-only service, no guardrail of its own \
    (relies on whatever calls it, e.g. the MCP server{% if primary_chat_agent in ["lg_agent", "both"] %} or lg_agent{% endif %}, to guard input)
{%- if primary_chat_agent in ["adk_agent", "both"] %}
  {{ source_root }}/agents/adk_agent — has a regex-based before_model_callback guardrail \
    in agent.py
{%- endif %}

Rules:
- Only flag a gap if you can POSITIVELY CONFIRM it is absent — read the actual source \
  before concluding, don't assume from the summary above.
- rag_agent having no guardrail of its own is a known, accepted asymmetry (it's a \
  retrieval-only service meant to be called by something that already guards input) — \
  do NOT flag this as a bug unless you find it's exposed directly with no caller-side \
  guard anywhere in the codebase.
{%- if primary_chat_agent == "both" %}
- Flag real discrepancies: a guardrail that's present but trivially bypassable, or a \
  regex pattern in one agent that catches something the other agent's pattern misses \
  for no apparent reason (inconsistent injection-pattern coverage between lg_agent and \
  adk_agent, specifically).
{%- else %}
- Flag a guardrail that's present but trivially bypassable.
{%- endif %}
"""


class SafeguardAgent(AkiraSubagent):
    name = "SafeguardAgent"

    async def scan(self, ctx: GitContext, path: str | None) -> list[AkiraFinding]:
        context = ""
{%- if primary_chat_agent in ["lg_agent", "both"] %}
        context += "## lg_agent/nodes/guardrail.py\n"
        context += _read("{{ source_root }}/agents/lg_agent/nodes/guardrail.py")
{%- endif %}
{%- if primary_chat_agent in ["adk_agent", "both"] %}
        context += "\n\n## adk_agent/agent.py\n"
        context += _read("{{ source_root }}/agents/adk_agent/agent.py")
{%- endif %}
        context += "\n\n## rag_agent/main.py\n"
        context += _read("{{ source_root }}/agents/rag_agent/main.py")
        return await self._call(_SYSTEM, context)
