"""SchemaAgent.

Question: Do the pydantic-settings field names collide across sibling agents'
settings.py files, and does AssistantResponse/schema.py mean the same thing
across all three example agents?
"""

from __future__ import annotations

import glob

from agents.akira.schema import AkiraFinding, GitContext

from .base import AkiraSubagent, _read

_SYSTEM = """\
You are SchemaAgent, checking schema and settings contract consistency across this \
project's example agents (glob {{ source_root }}/agents/*/settings.py and */schema.py \
— whichever agents actually exist in this project; don't assume all of \
lg_agent/rag_agent/adk_agent are present, check what the glob actually returned).

Look for BUGS, not design differences. Specifically:
- settings.py field-NAME collisions across agents: pydantic-settings binds by field name \
  to an identically-named env var regardless of which class declares it. Two agents' \
  Settings classes sharing a field name (e.g. both calling something `vectordb_path`) \
  will silently read the SAME env var — a real bug if the two paths point at \
  incompatible data (different DB schemas), harmless if the shared value is meant to \
  be shared (e.g. anthropic_api_key). Flag only the former.
- schema.py field drift: Source/ChatResponse-style models — any field renamed in one \
  agent that a shared caller (the MCP server, another agent) depends on under the \
  original name?
- Hardcoded model strings or ports duplicated across agents that would silently diverge \
  if changed in only one place.

Do NOT flag intentional differences between agents (lg_agent's BM25 retrieval vs \
rag_agent's embedding-based retrieval are deliberately different mechanisms, not a bug).
"""


class SchemaAgent(AkiraSubagent):
    name = "SchemaAgent"

    async def scan(self, ctx: GitContext, path: str | None) -> list[AkiraFinding]:
        context = ""
        for settings_file in sorted(glob.glob("{{ source_root }}/agents/*/settings.py")):
            context += f"\n\n## {settings_file}\n" + _read(settings_file, 4000)
        for schema_file in sorted(glob.glob("{{ source_root }}/agents/*/schema.py")):
            context += f"\n\n## {schema_file}\n" + _read(schema_file, 4000)
        return await self._call(_SYSTEM, context)
