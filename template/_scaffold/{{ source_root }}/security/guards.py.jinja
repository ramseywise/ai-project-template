"""The three guard layers: input guard, content filter, output filter.

What call sites use. Each layer returns a `GuardResult` rather than raising, so
an agent node decides what a block means (refuse, escalate, retry) instead of
having control flow torn out from under it.

Layer order around one agent turn:

    check_input(user_text)      -- before the model call
    filter_content(tool_output) -- before untrusted text enters the prompt
    check_output(model_text)    -- after the model call, BEFORE tracing
{% if data_sensitivity in ["restricted", "secret"] %}
Ordering contract (data_sensitivity={{ data_sensitivity }}): `check_output()` runs
BEFORE `observability/tracing.py`'s `redact()` -- the scrubbed text is what gets
traced, so a leak the model emitted never reaches the tracing backend even in
redacted form. CLAUDE.md and DESIGN.md both state raw field values must never
reach observability tooling; this ordering is that guarantee. Do not trace the
pre-filter string.
{%- endif %}
"""

from __future__ import annotations

import logging
import re
from dataclasses import dataclass, field
from typing import Any

from .settings import settings

log = logging.getLogger(__name__)


@dataclass(frozen=True)
class GuardResult:
    """Verdict from one guard layer.

    `text` is always safe to use downstream: the original when allowed, the
    scrubbed or refusal text when not. Call sites that ignore `blocked` and just
    use `text` still get the safe value -- the fallback is the safe one by
    construction, not by convention.
    """

    text: str
    blocked: bool = False
    # Machine-readable rule ids ("input.too_long"), never shown to the caller --
    # they are for logs, traces, and evals.
    reasons: tuple[str, ...] = field(default_factory=tuple)

    @property
    def allowed(self) -> bool:
        return not self.blocked


# --- Layer 1: input guard -------------------------------------------------
# Runs on the untrusted user turn, before any model call. Cheap deterministic
# checks only -- an LLM-based classifier here doubles latency and cost on every
# turn and is itself injectable.

# Instruction-override patterns. Deliberately narrow: these match imperative
# attempts to restate the system prompt, not any mention of the words. Broad
# patterns here cause false refusals on legitimate questions ABOUT prompts.
_INJECTION_PATTERNS: tuple[re.Pattern[str], ...] = (
    re.compile(r"\bignore\s+(all\s+|any\s+)?(previous|prior|above)\s+instructions?\b", re.I),
    re.compile(r"\bdisregard\s+(all\s+|any\s+)?(previous|prior|above)\b", re.I),
    re.compile(r"\byou\s+are\s+now\s+(a|an|the)\b", re.I),
    re.compile(r"\b(reveal|print|repeat|show)\s+(me\s+)?(your|the)\s+system\s+prompt\b", re.I),
    re.compile(r"\bdeveloper\s+mode\b", re.I),
)


def check_input(text: str) -> GuardResult:
    """Screen an untrusted user turn before it reaches the model.

    Fails OPEN when disabled, CLOSED on internal error: a guard that crashes
    must not become an availability hole that passes traffic unchecked.
    """
    if not settings.input_guard_enabled:
        return GuardResult(text=text)

    try:
        reasons: list[str] = []

        if len(text) > settings.max_input_chars:
            reasons.append("input.too_long")

        for pattern in _INJECTION_PATTERNS:
            if pattern.search(text):
                reasons.append("input.injection_pattern")
                break

        if reasons:
            log.warning("security.input.blocked", extra={"reasons": reasons})
            return GuardResult(text=settings.refusal_message, blocked=True, reasons=tuple(reasons))
        return GuardResult(text=text)
    except Exception as exc:  # fail closed -- see docstring
        log.error("security.input.failed", extra={"error": str(exc)})
        return GuardResult(
            text=settings.refusal_message, blocked=True, reasons=("input.guard_error",)
        )


# --- Layer 2: content filter ----------------------------------------------
# Runs on text from tools, retrieval, and other non-user sources before it is
# concatenated into a prompt. This is the indirect-injection seam: a poisoned
# document is not a user turn, so layer 1 never sees it.

_NEUTRALIZED = "[filtered]"


def filter_content(text: str, *, source: str = "tool") -> GuardResult:
    """Neutralize instruction-shaped text in retrieved/tool content.

    Neutralizes rather than blocks: a retrieved document containing one
    injection line is still useful for its other content, and dropping the whole
    passage silently degrades answers in ways that look like retrieval bugs.
    """
    if not settings.content_filter_enabled:
        return GuardResult(text=text)

    try:
        reasons: list[str] = []
        filtered = text

        for pattern in _INJECTION_PATTERNS:
            filtered, count = pattern.subn(_NEUTRALIZED, filtered)
            if count:
                reasons.append("content.injection_pattern")

        if reasons:
            log.warning(
                "security.content.filtered",
                extra={"source": source, "reasons": sorted(set(reasons))},
            )
            # Not `blocked` -- the text is usable, just neutralized.
            return GuardResult(text=filtered, reasons=tuple(sorted(set(reasons))))
        return GuardResult(text=text)
    except Exception as exc:  # fail closed -- drop the untrusted content entirely
        log.error("security.content.failed", extra={"source": source, "error": str(exc)})
        return GuardResult(text="", blocked=True, reasons=("content.filter_error",))


# --- Layer 3: output filter -----------------------------------------------
# Runs on model output before it reaches the caller AND before it is traced.

{% if data_sensitivity in ["restricted", "secret"] -%}
# PII shapes scrubbed from model output. Structural patterns, not field names --
# observability/tracing.py's REDACTED_FIELDS handles the keyed case; this catches
# values the model emitted inline in prose, where there is no key to match on.
_PII_PATTERNS: tuple[tuple[re.Pattern[str], str], ...] = (
    (re.compile(r"[\w.+-]+@[\w-]+\.[\w.]+"), "[EMAIL]"),
    (re.compile(r"\b\d{3}-\d{2}-\d{4}\b"), "[SSN]"),
    (re.compile(r"\b(?:\+?1[-.\s]?)?\(?\d{3}\)?[-.\s]?\d{3}[-.\s]?\d{4}\b"), "[PHONE]"),
    (re.compile(r"\b(?:\d[ -]?){13,16}\b"), "[CARD]"),
)
{% endif -%}
# Credential shapes never belong in model output regardless of data_sensitivity --
# a leaked key is a breach at every classification level.
_SECRET_PATTERNS: tuple[tuple[re.Pattern[str], str], ...] = (
    (re.compile(r"\bsk-[A-Za-z0-9_-]{16,}\b"), "[REDACTED_KEY]"),
    (re.compile(r"\bAKIA[0-9A-Z]{16}\b"), "[REDACTED_KEY]"),
    (re.compile(r"\bgh[pousr]_[A-Za-z0-9]{20,}\b"), "[REDACTED_KEY]"),
)


def check_output(text: str) -> GuardResult:
    """Scrub model output before it reaches the caller or the tracer.

    Call this BEFORE handing text to `observability.tracing`: the scrubbed
    string is what should be traced, logged, and returned. Fails CLOSED -- on
    internal error the refusal message is returned rather than unscrubbed text.
    """
    if not settings.output_filter_enabled:
        return GuardResult(text=text)

    try:
        reasons: list[str] = []
        scrubbed = text

        for pattern, placeholder in _SECRET_PATTERNS:
            scrubbed, count = pattern.subn(placeholder, scrubbed)
            if count:
                reasons.append("output.credential")
{%- if data_sensitivity in ["restricted", "secret"] %}

        if settings.scrub_output_pii:
            for pattern, placeholder in _PII_PATTERNS:
                scrubbed, count = pattern.subn(placeholder, scrubbed)
                if count:
                    reasons.append("output.pii")
{%- endif %}

        if reasons:
            log.warning("security.output.scrubbed", extra={"reasons": sorted(set(reasons))})
            # Scrubbed, not blocked: the answer is still delivered, minus the
            # leaked values. Blocking here would turn one bad token into a
            # dropped response.
            return GuardResult(text=scrubbed, reasons=tuple(sorted(set(reasons))))
        return GuardResult(text=text)
    except Exception as exc:  # fail closed -- never return unscrubbed text
        log.error("security.output.failed", extra={"error": str(exc)})
        return GuardResult(
            text=settings.refusal_message, blocked=True, reasons=("output.filter_error",)
        )


def guard_turn(user_text: str, model_call: Any) -> GuardResult:
    """Run all three layers around one agent turn -- the reference ordering.

    `model_call` is a callable taking the guarded input and returning the model's
    text. Copy this shape into your agent node rather than importing it if the
    node needs to branch on `blocked` between layers.
    """
    inbound = check_input(user_text)
    if inbound.blocked:
        return inbound
    return check_output(model_call(inbound.text))
