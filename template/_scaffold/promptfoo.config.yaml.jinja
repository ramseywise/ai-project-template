# Promptfoo eval config — runs alongside (not replacing) the Python heuristic
# eval suite in evals/. Targets rag_agent's /chat endpoint (shared infra,
# always present regardless of primary_chat_agent) via promptfoo's http
# provider. Start the server first, then run the eval:
#   make rag-up
#   make promptfoo-eval
#
# Port matches rag_agent/settings.py's rag_port default (8011) — update both
# if you change one.

description: "{{ project_name }} — promptfoo eval against rag_agent's /chat endpoint"

providers:
  - id: http
    config:
      url: http://localhost:8011/chat
      method: POST
      headers:
        Content-Type: application/json
      body:
        message: {% raw %}"{{prompt}}"{% endraw %}
        thread_id: "promptfoo-eval"
      transformResponse: "json.message"

prompts:
  - {% raw %}"{{question}}"{% endraw %}

tests:
  - vars:
      question: "How often should I descale the machine?"
    assert:
      - type: contains
        value: "descale"
  - vars:
      question: "Can I use vinegar to descale my machine?"
    assert:
      - type: contains
        value: "vinegar"
  - vars:
      question: "How do I clean the steam wand?"
    assert:
      - type: contains
        value: "steam wand"
