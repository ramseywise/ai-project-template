/**
 * The three guard layers: input guard, content filter, output filter.
 *
 * What call sites use. Each layer returns a `GuardResult` rather than throwing,
 * so the agent handler decides what a block means (refuse, escalate, retry)
 * instead of having control flow torn out from under it.
 *
 * Layer order around one agent turn:
 *
 *   checkInput(userText)        -- before the generateText/streamText call
 *   filterContent(toolOutput)   -- before untrusted text enters the prompt
 *   checkOutput(modelText)      -- after the model call, BEFORE tracing
 * {% if data_sensitivity in ["restricted", "secret"] %}
 * Ordering contract (data_sensitivity={{ data_sensitivity }}): `checkOutput()` runs
 * BEFORE any observability/tracing call — the scrubbed text is what gets
 * traced, so a leak the model emitted never reaches the tracing backend even in
 * redacted form. Do not trace the pre-filter string.
 * {%- endif %}
 */

import { settings } from "./settings.js";

// ---------------------------------------------------------------------------
// Result type
// ---------------------------------------------------------------------------

export interface GuardResult {
  /** Always safe to use downstream: original when allowed, scrubbed/refusal when not. */
  text: string;
  blocked: boolean;
  /** Machine-readable rule ids ("input.too_long") — for logs/traces/evals, never shown to callers. */
  reasons: readonly string[];
}

function allowed(r: GuardResult): boolean {
  return !r.blocked;
}

// ---------------------------------------------------------------------------
// Injection patterns (shared across layers)
// Deliberately narrow: match imperative attempts to restate the system prompt,
// not any mention of the words. Broad patterns cause false refusals on
// legitimate questions ABOUT prompts.
// ---------------------------------------------------------------------------

const INJECTION_PATTERNS: RegExp[] = [
  /\bignore\s+(?:all\s+|any\s+)?(?:previous|prior|above)\s+instructions?\b/i,
  /\bdisregard\s+(?:all\s+|any\s+)?(?:previous|prior|above)\b/i,
  /\byou\s+are\s+now\s+(?:a|an|the)\b/i,
  /\b(?:reveal|print|repeat|show)\s+(?:me\s+)?(?:your|the)\s+system\s+prompt\b/i,
  /\bdeveloper\s+mode\b/i,
];

// ---------------------------------------------------------------------------
// Layer 1: input guard
// Runs on the untrusted user turn, before any model call. Cheap deterministic
// checks only — an LLM-based classifier here doubles latency and cost on every
// turn and is itself injectable.
// ---------------------------------------------------------------------------

/**
 * Screen an untrusted user turn before it reaches the model.
 *
 * Fails OPEN when disabled, CLOSED on internal error: a guard that crashes
 * must not become an availability hole that passes traffic unchecked.
 */
export function checkInput(text: string): GuardResult {
  if (!settings.inputGuardEnabled) {
    return { text, blocked: false, reasons: [] };
  }

  try {
    const reasons: string[] = [];

    if (text.length > settings.maxInputChars) {
      reasons.push("input.too_long");
    }

    for (const pattern of INJECTION_PATTERNS) {
      if (pattern.test(text)) {
        reasons.push("input.injection_pattern");
        break;
      }
    }

    if (reasons.length > 0) {
      console.warn("security.input.blocked", { reasons });
      return { text: settings.refusalMessage, blocked: true, reasons };
    }
    return { text, blocked: false, reasons: [] };
  } catch (err) {
    // Fail closed — see docstring
    console.error("security.input.failed", { error: String(err) });
    return {
      text: settings.refusalMessage,
      blocked: true,
      reasons: ["input.guard_error"],
    };
  }
}

// ---------------------------------------------------------------------------
// Layer 2: content filter
// Runs on text from tools and other non-user sources before it is concatenated
// into a prompt. This is the indirect-injection seam: a poisoned document is
// not a user turn, so layer 1 never sees it.
// ---------------------------------------------------------------------------

const NEUTRALIZED = "[filtered]";

/**
 * Neutralize instruction-shaped text in tool/retrieved content.
 *
 * Neutralizes rather than blocks: a retrieved document containing one
 * injection line is still useful for its other content, and dropping the whole
 * passage silently degrades answers in ways that look like retrieval bugs.
 */
export function filterContent(
  text: string,
  source: string = "tool",
): GuardResult {
  if (!settings.contentFilterEnabled) {
    return { text, blocked: false, reasons: [] };
  }

  try {
    const reasons: string[] = [];
    let filtered = text;

    for (const pattern of INJECTION_PATTERNS) {
      const patternG = new RegExp(pattern.source, pattern.flags.includes("g") ? pattern.flags : pattern.flags + "g");
      const before = filtered;
      filtered = filtered.replace(patternG, NEUTRALIZED);
      if (filtered !== before) {
        reasons.push("content.injection_pattern");
      }
    }

    if (reasons.length > 0) {
      console.warn("security.content.filtered", {
        source,
        reasons: [...new Set(reasons)].sort(),
      });
      // Not `blocked` — the text is usable, just neutralized.
      return { text: filtered, blocked: false, reasons: [...new Set(reasons)].sort() };
    }
    return { text, blocked: false, reasons: [] };
  } catch (err) {
    // Fail closed — drop the untrusted content entirely
    console.error("security.content.failed", { source, error: String(err) });
    return { text: "", blocked: true, reasons: ["content.filter_error"] };
  }
}

// ---------------------------------------------------------------------------
// Layer 3: output filter
// Runs on model output before it reaches the caller AND before it is traced.
// ---------------------------------------------------------------------------

{% if data_sensitivity in ["restricted", "secret"] -%}
// PII shapes scrubbed from model output. Structural patterns, not field names —
// catches values the model emitted inline in prose, where there is no key to match on.
const PII_PATTERNS: [RegExp, string][] = [
  [/[\w.+-]+@[\w-]+\.[\w.]+/g, "[EMAIL]"],
  [/\b\d{3}-\d{2}-\d{4}\b/g, "[SSN]"],
  [/\b(?:\+?1[-.\s]?)?\(?\d{3}\)?[-.\s]?\d{3}[-.\s]?\d{4}\b/g, "[PHONE]"],
  [/\b(?:\d[ -]?){13,16}\b/g, "[CARD]"],
];
{% endif -%}
// Credential shapes never belong in model output regardless of data_sensitivity —
// a leaked key is a breach at every classification level.
const SECRET_PATTERNS: [RegExp, string][] = [
  [/\bsk-[A-Za-z0-9_-]{16,}\b/g, "[REDACTED_KEY]"],
  [/\bAKIA[0-9A-Z]{16}\b/g, "[REDACTED_KEY]"],
  [/\bgh[pousr]_[A-Za-z0-9]{20,}\b/g, "[REDACTED_KEY]"],
];

/**
 * Scrub model output before it reaches the caller or the tracer.
 *
 * Call this BEFORE handing text to any observability/tracing call: the scrubbed
 * string is what should be traced, logged, and returned. Fails CLOSED — on
 * internal error the refusal message is returned rather than unscrubbed text.
 */
export function checkOutput(text: string): GuardResult {
  if (!settings.outputFilterEnabled) {
    return { text, blocked: false, reasons: [] };
  }

  try {
    const reasons: string[] = [];
    let scrubbed = text;

    for (const [pattern, placeholder] of SECRET_PATTERNS) {
      const before = scrubbed;
      scrubbed = scrubbed.replace(pattern, placeholder);
      if (scrubbed !== before) {
        reasons.push("output.credential");
      }
    }
{%- if data_sensitivity in ["restricted", "secret"] %}

    if (settings.scrubOutputPii) {
      for (const [pattern, placeholder] of PII_PATTERNS) {
        const before = scrubbed;
        scrubbed = scrubbed.replace(pattern, placeholder);
        if (scrubbed !== before) {
          reasons.push("output.pii");
        }
      }
    }
{%- endif %}

    if (reasons.length > 0) {
      console.warn("security.output.scrubbed", {
        reasons: [...new Set(reasons)].sort(),
      });
      // Scrubbed, not blocked: the answer is still delivered, minus the leaked
      // values. Blocking here would turn one bad token into a dropped response.
      return { text: scrubbed, blocked: false, reasons: [...new Set(reasons)].sort() };
    }
    return { text, blocked: false, reasons: [] };
  } catch (err) {
    // Fail closed — never return unscrubbed text
    console.error("security.output.failed", { error: String(err) });
    return {
      text: settings.refusalMessage,
      blocked: true,
      reasons: ["output.filter_error"],
    };
  }
}

// ---------------------------------------------------------------------------
// Convenience wrapper
// ---------------------------------------------------------------------------

/**
 * Run all three layers around one agent turn — the reference ordering.
 *
 * `modelCall` is an async function taking the guarded input and returning the
 * model's text. Copy this shape into your handler rather than importing it if
 * you need to branch on `blocked` between layers (e.g. to stream the refusal
 * message instead of returning it as a resolved string).
 */
export async function guardTurn(
  userText: string,
  modelCall: (safeInput: string) => Promise<string>,
): Promise<GuardResult> {
  const inbound = checkInput(userText);
  if (!allowed(inbound)) {
    return inbound;
  }
  const modelText = await modelCall(inbound.text);
  return checkOutput(modelText);
}
