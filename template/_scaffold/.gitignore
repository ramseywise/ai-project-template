# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.venv-*/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyright_cache/

# Dependency lockfile is committed — but local env caches aren't
.uv-cache/

# Env / secrets
.env
.env.local
.env.*.local

# Data artifacts (runtime outputs — the committed example corpus lives in data/corpus/)
data/processed/
data/stores/
data/datasets/

# Notebooks
nbks/__marimo__/

# Eval reports — generated by `make eval-heuristic` / `make eval-render`
# (this is a plain, non-.jinja file, so `eval_root` can't be templated here —
# hardcoded to the default "evals"; update if you rename eval_root)
evals/reports/output/

# Akira findings — generated by `make akira-kaneda`, consumed by `make akira-dao`.
# Review the doc before running dao; ephemeral once triaged, not meant to accumulate
# in git history (same reasoning as eval reports above).
src/agents/akira/findings/*.md
src/agents/akira/findings/*.json

# Node (if a TypeScript component was added)
node_modules/

# Editor / OS
.DS_Store
*.swp

# Claude Code local-only state
.claude/.phase_complete
.claude/friction-log.jsonl
