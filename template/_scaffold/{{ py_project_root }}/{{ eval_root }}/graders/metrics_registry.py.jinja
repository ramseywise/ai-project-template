{% endif %}from evals.models import EvalInteraction, GraderResult, MetricSummary


@dataclass(frozen=True)
class MetricDefinition:
    name: str
    description: str
    heuristic: Callable[[EvalInteraction], GraderResult | None]
    judge_cls: type
    summarize: Callable[[list[GraderResult]], MetricSummary]
    # targets.yaml key gating this metric in `--gate` runs (judge pass-rate
    # when judges ran, heuristic pass-rate otherwise).
    targets_key: str


