"""Central registry of interaction-eval metrics — the single wiring point.

pipelines/grade.py, pipelines/calibration.py, and reports/ discover enabled
metrics HERE; never hardcode metric names elsewhere. To add a project-specific
metric: write graders/heuristic/<name>.py (+ optionally graders/judges/<name>.py
and metrics/<name>.py) and register it below.

Rendered by copier — only the metrics selected in `eval_metrics` at generation
time appear. Retrieval is not in this registry: it grades against the golden
QA set via its own pipeline (pipelines/run.py), not against recorded
interactions.
"""

from __future__ import annotations

from collections.abc import Callable
from dataclasses import dataclass

