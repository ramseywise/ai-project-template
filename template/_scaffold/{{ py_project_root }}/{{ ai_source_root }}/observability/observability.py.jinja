"""Tracing-provider factory — the ONLY module that instantiates a client.

`.claude/hooks/sdk_lint.sh` (B3) greps for bare `Langfuse(` / `langsmith.Client(`
outside a file named `observability.py` and flags it. Keep the provider client
construction here so the provider stays swappable in one place; everywhere else
call `get_tracer()`.

Provider selected at scaffold time: {{ observability_provider }}
(swap with `copier update -d observability_provider=…`).
"""

from __future__ import annotations

import logging
from functools import lru_cache
from typing import Any

from .settings import settings

log = logging.getLogger(__name__)


class NoOpTracer:
    """Fallback when tracing is disabled or the provider SDK isn't installed.

    Every call site can assume a tracer exists, so no `if tracer is not None`
    branches leak into agent/node code.
    """

    def span(self, name: str, **attributes: Any) -> Any:
        return _NoOpSpan()

    def score(self, *, name: str, value: float, trace_id: str | None = None, **_: Any) -> None:
        return None

    def flush(self) -> None:
        return None


class _NoOpSpan:
    def __enter__(self) -> _NoOpSpan:
        return self

    def __exit__(self, *exc_info: object) -> None:
        return None

    def update(self, **_: Any) -> None:
        return None


@lru_cache(maxsize=1)
def get_tracer() -> Any:
    """Return the process-wide tracing client (cached).

    Returns a NoOpTracer when the provider is 'none', when credentials are
    absent, or when the SDK isn't installed — tracing must never be the reason
    an agent fails to start.
    """
    provider = settings.observability_provider

    if provider == "none" or not settings.tracing_enabled:
        log.debug("observability.tracer.disabled", extra={"provider": provider})
        return NoOpTracer()

{%- if observability_provider == "langsmith" %}
    if not settings.langsmith_api_key:
        log.warning("observability.tracer.missing_credentials", extra={"provider": "langsmith"})
        return NoOpTracer()
    try:
        from langsmith import Client
    except ImportError:
        log.warning("observability.tracer.sdk_missing", extra={"provider": "langsmith"})
        return NoOpTracer()
    log.info("observability.tracer.ready", extra={"provider": "langsmith"})
    return Client(api_key=settings.langsmith_api_key)
{%- else %}
    if not (settings.langfuse_public_key and settings.langfuse_secret_key):
        log.warning("observability.tracer.missing_credentials", extra={"provider": "langfuse"})
        return NoOpTracer()
    try:
        from langfuse import Langfuse
    except ImportError:
        log.warning("observability.tracer.sdk_missing", extra={"provider": "langfuse"})
        return NoOpTracer()
    log.info("observability.tracer.ready", extra={"provider": "langfuse"})
    return Langfuse(
        public_key=settings.langfuse_public_key,
        secret_key=settings.langfuse_secret_key,
        host=settings.langfuse_host,
    )
{%- endif %}
