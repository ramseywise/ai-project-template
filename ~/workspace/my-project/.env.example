# Copied to .env by project_init.sh — fill in real values, never commit .env itself.

# --- LLM provider (src/agents/lg_agent/clients/llm.py factory reads this) ---
ANTHROPIC_API_KEY=
LG_MODEL=claude-haiku-4-5-20251001

# --- Example agent (src/agents/lg_agent) ---
LG_PORT=8010
VECTORDB_PATH=data/stores/vectordb.duckdb
LG_CHECKPOINTER=memory   # memory | sqlite — see .agents/skills/langgraph-persistence

# --- MCP client (src/agents/lg_agent/clients/mcp.py) ---
MCP_ENABLED=true
MCP_SERVER_DIR=mcp_servers/my-project

# --- Example agent (src/agents/rag_agent) — same corpus, embedding-based retrieval ---
RAG_MODEL=claude-haiku-4-5-20251001
RAG_PORT=8011
RAG_VECTORDB_PATH=data/stores/rag_vectordb.duckdb
RAG_CHECKPOINTER=memory
EMBEDDING_MODEL=all-MiniLM-L6-v2
CONFIDENCE_THRESHOLD=0.25

# --- Example agent (src/agents/adk_agent) — Google ADK, MCP via native McpToolset ---
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_API_KEY=
ADK_PORT=8000
GATEWAY_API_KEY=

# --- Observability (optional — leave blank to disable) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=my-project
